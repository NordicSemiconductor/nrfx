            <addressOffset>0x1000</addressOffset>
            <access>read-write</access>
            <resetValue>0x3FC30000</resetValue>
            <size>0x20</size>
            <fields>
              <field>
                <name>IP</name>
                <description>Interrupt Pending bit.</description>
                <lsb>0</lsb>
                <msb>0</msb>
