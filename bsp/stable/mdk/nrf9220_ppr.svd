                </enumeratedValue>
                <enumeratedValue>
                  <name>Implemented</name>
                  <description>Claim bit 1 is implemented.</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
              <enumeratedValues>
                <usage>write</usage>
                <enumeratedValue>
                  <name>Set</name>
                  <description>Set claim bit 1.</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>BIT_2</name>
              <description>Set claim bit 2 and check if bit is implemented or not.</description>
              <lsb>2</lsb>
