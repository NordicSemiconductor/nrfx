                <description>Maximum number of interrupts supported.</description>
                <lsb>0</lsb>
                <msb>12</msb>
              </field>
              <field>
                <name>VERSION</name>
                <description>Version</description>
                <lsb>13</lsb>
                <msb>20</msb>
              </field>
              <field>
                <name>NUMTRIGGER</name>
                <description>Number of maximum interrupt triggers supported</description>
                <lsb>25</lsb>
                <msb>30</msb>
              </field>
            </fields>
          </register>
          <register>
            <dim>0x1E0</dim>
            <dimIncrement>0x4</dimIncrement>
