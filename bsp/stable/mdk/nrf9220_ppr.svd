                <enumeratedValues>
                  <enumeratedValue>
                    <name>EdgeTriggered</name>
                    <description>Interrupts are edge-triggered</description>
                    <value>0x1</value>
                  </enumeratedValue>
                </enumeratedValues>
              </field>
              <field>
                <name>MODE</name>
                <description>Privilege mode.</description>
                <lsb>22</lsb>
