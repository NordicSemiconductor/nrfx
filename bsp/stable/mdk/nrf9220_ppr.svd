                <enumeratedValue>
                  <name>Ratio150</name>
                  <description>Ratio of 100</description>
                  <value>0x5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Ratio192</name>
                  <description>Ratio of 192</description>
                  <value>0x6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Custom</name>
                  <description>Custom. The decimation rate can be changed using the FILTER.CTRL[31:25] bits</description>
                  <value>0x7</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
