            <field>
              <name>BIT_3</name>
              <description>Set claim bit 3 and check if bit is implemented or not.</description>
              <lsb>3</lsb>
              <msb>3</msb>
              <enumeratedValues>
                <usage>read</usage>
                <enumeratedValue>
