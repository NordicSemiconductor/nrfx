          <resetValue>0x000000A4</resetValue>
          <size>0x20</size>
          <fields>
            <field>
              <name>PART_0</name>
              <description>Bits [7:0] of the components 12 bit part number. The  designer of the component assigns this part number.</description>
              <lsb>0</lsb>
              <msb>7</msb>
            </field>
          </fields>
        </register>
        <register>
          <name>PERIPHID1</name>
          <description>Peripheral ID1 Register</description>
          <addressOffset>0xFE4</addressOffset>
          <access>read-only</access>
          <resetValue>0x000000B9</resetValue>
          <size>0x20</size>
          <fields>
            <field>
              <name>PART_1</name>
              <description>Bits[11:8] of the components 12 bit part number. The  designer of the component assigns this part number.</description>
              <lsb>0</lsb>
              <msb>3</msb>
            </field>
            <field>
              <name>DES_0</name>
              <description>Bits[3:0] of the JEDEC JEP106 identity code. This code, along with bits[6:4] of the identity code defined in PERIPHID2 register and the continuation code defined in PERIPHID4 register, gives the designer of the component.</description>
              <lsb>4</lsb>
              <msb>7</msb>
            </field>
          </fields>
        </register>
        <register>
          <name>PERIPHID2</name>
          <description>Peripheral ID2 Register</description>
          <addressOffset>0xFE8</addressOffset>
          <access>read-only</access>
          <resetValue>0x0000000B</resetValue>
          <size>0x20</size>
          <fields>
            <field>
              <name>DES_1</name>
              <description>Bits[6:4] of the JEDEC JEP106 identity code. This code, along with bits[3:0] of the identity code defined in PERIPHID1 register and the continuation code defined in PERIPHID4 register, gives the designer of the component.</description>
              <lsb>0</lsb>
              <msb>2</msb>
            </field>
            <field>
              <name>JEDEC</name>
              <description>Always set. Indicates if the JEDEC assigned designer ID is used.</description>
              <lsb>3</lsb>
              <msb>3</msb>
            </field>
            <field>
              <name>REVISION</name>
              <description>An incremental value starting from 0x0 for the first revision of this component. This increases by 1 for both major and minor revisions and is used  to identify the major or minor revisions.</description>
              <lsb>4</lsb>
              <msb>7</msb>
            </field>
          </fields>
        </register>
        <register>
          <name>PERIPHID3</name>
          <description>Peripheral ID3 Register</description>
          <addressOffset>0xFEC</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <size>0x20</size>
          <fields>
            <field>
              <name>CMOD</name>
              <description>Indicates if the customer modified the behavior of the component. In most cases, this field might be zero. The customer changes this value on modifications to this component.</description>
              <lsb>0</lsb>
              <msb>3</msb>
            </field>
            <field>
              <name>REVAND</name>
              <description>Indicates minor errata fixes specific to the revision of the component being used, for example metal fixes after implementation. In most cases, this field might be zero. ARM recommends that the component designers ensure that a metal fix can change this field if required, for example, by driving it from registers that reset to zero.</description>
              <lsb>4</lsb>
              <msb>7</msb>
            </field>
          </fields>
        </register>
