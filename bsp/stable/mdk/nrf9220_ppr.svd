  <peripherals>
    <peripheral>
      <name>GLOBAL_MICR</name>
      <description>MICR</description>
      <baseAddress>0x0FFF6000</baseAddress>
      <!--Security dma=NA-->
      <!--Security securemapping=NS-->
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <groupName>MICR</groupName>
      <size>0x20</size>
      <registers>
        <cluster>
          <name>SIPINFO</name>
          <description>SIP-specific device info.</description>
          <headerStructName>GLOBAL_MICR_SIPINFO</headerStructName>
          <access>read-write</access>
          <addressOffset>0x080</addressOffset>
          <register>
            <dim>0x2</dim>
            <dimIncrement>0x4</dimIncrement>
            <name>PARTNO[%s]</name>
            <description>Description collection: SIP part number, encoded in ASCII.</description>
            <addressOffset>0x000</addressOffset>
            <access>read-only</access>
            <resetValue>0xFFFFFFFF</resetValue>
            <size>0x20</size>
            <fields>
              <field>
                <name>PARTNO</name>
                <description>Bits [(n+1)*31-1:n*32] of the SIP part number</description>
                <lsb>0</lsb>
                <msb>31</msb>
              </field>
            </fields>
          </register>
          <register>
            <dim>0x4</dim>
            <dimIncrement>0x1</dimIncrement>
            <name>VARIANT[%s]</name>
            <description>Description collection: SIP VARIANT, encoded in ASCII, ex SIAA, SIBA or SICA.</description>
            <addressOffset>0x008</addressOffset>
            <access>read-only</access>
            <resetValue>0xFF</resetValue>
            <dataType>uint8_t</dataType>
            <size>0x8</size>
            <fields>
              <field>
                <name>VARIANT</name>
                <lsb>0</lsb>
                <msb>7</msb>
              </field>
            </fields>
          </register>
          <register>
            <dim>0x9</dim>
            <dimIncrement>0x4</dimIncrement>
            <name>SERIALNO[%s]</name>
            <description>Description collection: SIP module serial number.</description>
            <addressOffset>0x2F0</addressOffset>
            <access>read-only</access>
            <resetValue>0xFFFFFFFF</resetValue>
            <size>0x20</size>
            <fields>
              <field>
                <name>SERIALNO</name>
                <lsb>0</lsb>
                <msb>31</msb>
              </field>
            </fields>
          </register>
        </cluster>
      </registers>
    </peripheral>
    <peripheral>
