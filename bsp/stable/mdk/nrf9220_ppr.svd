              </enumeratedValues>
            </field>
            <field>
              <name>MULT_2</name>
              <description>Multiply the Trigger Counter by 2^n.</description>
              <lsb>2</lsb>
              <msb>2</msb>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Disabled</name>
                  <description>Multiplier disabled.</description>
                  <value>0x0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Enabled</name>
                  <description>Multiplier enabled.</description>
                  <value>0x1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>MULT_3</name>
              <description>Multiply the Trigger Counter by 2^n.</description>
              <lsb>3</lsb>
