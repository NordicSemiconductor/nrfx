            <field>
              <name>ATVALID</name>
              <description>A read returns the value of the atvalids[n] signal, where the value of the CTRLREG at 0x000 defines n.
A write outputs the value to atvalidm.</description>
              <lsb>0</lsb>
              <msb>0</msb>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Low</name>
                  <description>Pin is logic 0.</description>
